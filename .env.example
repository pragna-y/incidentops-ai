# IncidentOps AI — Environment Configuration
# Copy this file to .env and fill in your values.
# All variables use the INCIDENTOPS_ prefix.

# ---------------------------------------------------------------------------
# Required for the `analyze` command (Google ADK multi-agent pipeline)
# Get a free key at: https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key-here

# ---------------------------------------------------------------------------
# Optional overrides (defaults shown)
# ---------------------------------------------------------------------------

# LLM model used by all ADK agents
INCIDENTOPS_MODEL_NAME=gemini-2.0-flash

# Minimum confidence score before auto-escalation (0.0 - 1.0)
INCIDENTOPS_CONFIDENCE_THRESHOLD=0.75

# Maximum log file size accepted
INCIDENTOPS_MAX_LOG_SIZE_MB=20.0

# Output directory for redacted logs and simulation reports
INCIDENTOPS_OUTPUT_DIR=output

# Runbook MCP server URL (used when running in Docker with SSE transport)
INCIDENTOPS_RUNBOOK_SERVER_URL=http://localhost:8090

# Enable verbose debug output
INCIDENTOPS_VERBOSE=false
